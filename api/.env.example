# Local development (Prisma CLI, running api outside Docker)
# Inside Docker the compose file sets DATABASE_URL to nmf-db:5432
DATABASE_URL=postgresql://nameforge:nameforge_dev@localhost:5434/nameforge_dev
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info

# Connector selection. 'stub' uses deterministic in-memory data; 'rdap' calls
# the real RDAP network via the IANA bootstrap.
DOMAIN_CONNECTOR=stub
RDAP_BOOTSTRAP_URL=https://data.iana.org/rdap/dns.json
RDAP_TIMEOUT_MS=8000
RDAP_CACHE_TTL_MS=3600000

# Companies House (UK company register). Provide a free API key from
# https://developer.company-information.service.gov.uk/ to enable live
# UK lookups. Without a key UK requests stay on the stub.
# COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk
COMPANIES_HOUSE_TIMEOUT_MS=8000
COMPANIES_HOUSE_CACHE_TTL_MS=3600000

# French company register (INPI/RNE + SIRENE) via the keyless government API
# at https://recherche-entreprises.api.gouv.fr. Set to 'recherche-entreprises'
# to enable live FR lookups; 'stub' (default) keeps FR offline.
FR_REGISTRY_CONNECTOR=stub
RECHERCHE_ENTREPRISES_BASE_URL=https://recherche-entreprises.api.gouv.fr
RECHERCHE_ENTREPRISES_TIMEOUT_MS=8000
RECHERCHE_ENTREPRISES_CACHE_TTL_MS=3600000
