# Local development (Prisma CLI, running api outside Docker)
# Inside Docker the compose file sets DATABASE_URL to nmf-db:5432
DATABASE_URL=postgresql://nameforge:nameforge_dev@localhost:5434/nameforge_dev
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info

# Connector selection. 'stub' uses deterministic in-memory data; 'rdap' calls
# the real RDAP network via the IANA bootstrap.
DOMAIN_CONNECTOR=stub
RDAP_BOOTSTRAP_URL=https://data.iana.org/rdap/dns.json
RDAP_TIMEOUT_MS=8000
RDAP_CACHE_TTL_MS=3600000
