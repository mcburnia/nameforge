POSTGRES_USER=nameforge
POSTGRES_PASSWORD=nameforge_dev
POSTGRES_DB=nameforge_dev

# Connector selection for nmf-api. 'stub' uses deterministic in-memory data;
# 'rdap' makes real RDAP calls via the IANA bootstrap.
DOMAIN_CONNECTOR=stub
RDAP_BOOTSTRAP_URL=https://data.iana.org/rdap/dns.json
RDAP_TIMEOUT_MS=8000
RDAP_CACHE_TTL_MS=3600000

# Companies House (UK). Provide a free API key from
# https://developer.company-information.service.gov.uk/ to enable live UK
# company lookups. Leave blank to keep UK on the stub.
# COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk
COMPANIES_HOUSE_TIMEOUT_MS=8000
COMPANIES_HOUSE_CACHE_TTL_MS=3600000

# French company register (INPI/RNE + SIRENE) via the keyless government API.
# Set to 'recherche-entreprises' to enable live FR lookups.
FR_REGISTRY_CONNECTOR=stub
RECHERCHE_ENTREPRISES_BASE_URL=https://recherche-entreprises.api.gouv.fr
RECHERCHE_ENTREPRISES_TIMEOUT_MS=8000
RECHERCHE_ENTREPRISES_CACHE_TTL_MS=3600000
